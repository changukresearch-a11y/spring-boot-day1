# JWT 서명 비밀키 (HS256 — 32바이트 이상)
JWT_SECRET=please-change-this-to-a-32-byte-minimum-secret-key

# JWT 만료 시간 (밀리초). 기본 1시간
JWT_EXPIRATION_MILLIS=3600000

# PostgreSQL 비밀번호 (docker-compose와 일치시킬 것)
POSTGRES_PASSWORD=postgres

# 구글 OAuth2 클라이언트 자격증명 (Day 4 B7~B8) — 구글 클라우드 콘솔에서 발급
# 콘솔의 "승인된 리디렉션 URI"에 아래 주소를 정확히 등록해야 합니다(오타 1글자도 redirect_uri_mismatch):
#   http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=changeme-google-client-id
GOOGLE_CLIENT_SECRET=changeme-google-client-secret

# OAuth2 로그인 성공 후 앱 JWT를 붙여 보낼 프런트 콜백 주소 (React dev 서버)
OAUTH2_REDIRECT_URI=http://localhost:5173/oauth/callback
